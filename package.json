{
  "name": "ripplecommunity",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter @rc/wallet dev",
    "build": "pnpm -r --filter=./packages/* build && pnpm -r --filter=./apps/* build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10",
      "ioredis": "5.10.1",
      "uuid": "^11.1.1",
      "qs": "^6.15.2",
      "multer": "^2.1.1",
      "js-yaml": "^4.1.1",
      "lodash": "^4.18.1",
      "file-type": "^21.3.1"
    }
  }
}
